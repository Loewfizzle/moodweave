# Spotify OAuth credentials — SERVER ONLY (no NEXT_PUBLIC_ prefix, so these
# are never bundled into the browser). Copy this file to .env.local and fill
# in your real values from:
#   https://developer.spotify.com/dashboard  ->  your app  ->  Settings

SPOTIFY_CLIENT_ID=your-client-id-here
SPOTIFY_CLIENT_SECRET=your-client-secret-here

# Must EXACTLY match a Redirect URI registered in the Spotify dashboard.
# Local dev uses the 127.0.0.1 loopback ("localhost" is disallowed by Spotify).
SPOTIFY_REDIRECT_URI=http://127.0.0.1:3000/api/auth/callback/spotify

# Spotify app credentials — SERVER ONLY (no NEXT_PUBLIC_ prefix, so they are
# never bundled into the browser). Used for the Client Credentials flow that
# powers search — no user login. Copy this file to .env.local and fill in your
# real values from:
#   https://developer.spotify.com/dashboard  ->  your app  ->  Settings

SPOTIFY_CLIENT_ID=your-client-id-here
SPOTIFY_CLIENT_SECRET=your-client-secret-here
